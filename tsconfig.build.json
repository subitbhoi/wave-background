{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "dist"
  },
  "include": ["src"],
  "exclude": ["dist", "dist-preview", "node_modules", "preview", "src/test", "src/**/*.test.ts", "src/**/*.test.tsx"]
}
